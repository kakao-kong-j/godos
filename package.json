{
  "name": "@kakao-kong-j/godos",
  "version": "1.0.0",
  "description": "Git-based interactive TUI TodoList CLI",
  "license": "ISC",
  "author": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kakao-kong-j/kodo.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/",
    "!dist/**/__tests__/",
    "!dist/**/*.map"
  ],
  "bin": {
    "godos": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "date-fns": "^4.1.0",
    "ink": "^5.2.1",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
